# ═══════════════════════════════════════════════════════════
# GastroMap v2 - Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ─── OpenRouter AI (Recommended) ───────────────────────────
# Get your API key: https://openrouter.ai/keys
# Free models available: DeepSeek V3.2, Llama 4, Nemotron, etc.
VITE_OPENROUTER_API_KEY=sk-or-v1-your-key-here

# AI Model to use (default: free DeepSeek V3.2)
# See all models: https://openrouter.ai/models
VITE_AI_MODEL=deepseek/deepseek-chat-v3-0324:free

# Site metadata for OpenRouter analytics
VITE_SITE_URL=http://localhost:5173
VITE_APP_NAME=GastroMap

# AI / OpenRouter (free models — no usage cost for free tier)
# Get your key at https://openrouter.ai/keys
# ⚠️ For production: proxy through a server-side edge function, never expose in bundle
VITE_OPENROUTER_API_KEY=
# Primary model (default: Llama 3.3 70B — free, tool use, 131K ctx)
VITE_AI_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Fallback model on rate limit (default: Qwen3 480B — free, 100+ languages, 262K ctx)
VITE_AI_MODEL_FALLBACK=qwen/qwen3-coder:free

# ─── Supabase Database ──────────────────────────────────────
# Get from: https://app.supabase.com/project/_/settings/api
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── App Configuration ──────────────────────────────────────
VITE_APP_VERSION=2.0.0

# ═══════════════════════════════════════════════════════════
# Available Free Models (OpenRouter):
# - deepseek/deepseek-chat-v3-0324:free (Recommended!)
# - nvidia/nemotron-3-super:free
# - qwen/qwen-3-coder-480b:free
# - meta-llama/llama-4-maverick:free
# - stepfun-ai/step-3.5-flash:free
# ═══════════════════════════════════════════════════════════
